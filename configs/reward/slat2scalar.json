{
    "models": {
        "model": {
            "name": "Slat2Scalar",
            "args": {
                "out_channels": 2,
                "cond_dim": 2,
                "latent_channels": 32,
                "model_channels": 64,
                "num_blocks": 1,
                "num_heads": 2,
                "dropout": 0.1,
                "mlp_ratio": 2.0,
                "attn_mode": "full",
                "use_rope": true,
                "qk_rms_norm": false,
                "use_checkpoint": false,
                "dtype": "bfloat16"
            }
        }
    },
    "dataset": {
        "name": "RewardDataset",
        "args": {
            "sim_csv": "/flux/vault/Conventional_Airplanes_sims/stability_paper_sweep.csv",
            "latent_meta_csv": "/flux/vault/99_dev_martin/trellis_diffusion/datasets/planes/metadata.csv",
            "sample_names_csv": "/flux/vault/Conventional_Airplanes_sims/train.csv",
            "join_key": "raw_filename",
            "target_keys": ["Cd", "Cl"],
            "cond_keys": ["AoA_deg", "Yaw_deg"]
        }
    },
    "trainer": {
        "name": "RewardTrainer",
        "args": {
            "eval_splits": {
                "test": "/flux/vault/Conventional_Airplanes_sims/test.csv",
                "val": "/flux/vault/Conventional_Airplanes_sims/validation.csv"
            },
            "max_steps": 10000,
            "batch_size_per_gpu": 64,
            "snapshot_batch_size": 512,
            "batch_split": 1,
            "optimizer": {
                "name": "AdamW",
                "args": {
                    "lr": 1e-4,
                    "weight_decay": 0.05
                }
            },
            "ema_rate": [],
            "fp16_mode": "inflat_all",
            "fp16_scale_growth": 0.001,
            "i_sample": 1000,
            "i_save": 5000
        }
    }
}